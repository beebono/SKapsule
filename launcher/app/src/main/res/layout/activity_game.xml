<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <SurfaceView
        android:id="@+id/game_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Touch Control overlay: hosts dynamic touch joysticks and buttons, and Edit mode UI. -->
    <com.skarm.launcher.touch.TouchControlOverlay
        android:id="@+id/touch_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/top_button_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:orientation="horizontal"
        android:layout_margin="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_layout"
            style="@style/Widget.Material3.Button.UnelevatedButton"
            app:cornerRadius="12dp"
            app:backgroundTint="#202020"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:alpha="0.55"
            android:text="⚙" />

        <!-- Exit is handled by Android Back (-> exit-confirm dialog). -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_keyboard"
            style="@style/Widget.Material3.Button.UnelevatedButton"
            app:cornerRadius="12dp"
            app:backgroundTint="#202020"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.55"
            android:text="@string/keyboard" />
    </LinearLayout>

    <!-- Invisible focusable view that hosts the soft-keyboard InputConnection and
         forwards typed input to SK (the SurfaceView can't host an IME). -->
    <com.skarm.launcher.ImeBridgeView
        android:id="@+id/ime_bridge"
        android:layout_width="1dp"
        android:layout_height="1dp" />

    <!-- Boot overlay: covers the otherwise-black gap between this Activity opening
         and SK rendering its first frame. Driven by NativeBridge.onLaunchStatus
         (JVM boot, getdown update, Steam auth) and dismissed on first frame.
         Drawn last so it sits on top of the SurfaceView. -->
    <LinearLayout
        android:id="@+id/boot_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/boot_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/boot_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/boot_starting"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
